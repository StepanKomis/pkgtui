def safe_add(win, y, x, text, attr=0):
    rows, cols = win.getmaxyx()
    if y < 0 or y >= rows or x < 0 or x >= cols:
        return
    avail = cols - x - (1 if y == rows - 1 else 0)
    if avail <= 0:
        return
    try:
        win.addstr(y, x, text[:avail], attr)
    except curses.error:
        pass


def draw_box(win, y, x, h, w, attr, title=""):
    inner = w - 2
    top = "╔" + "═" * inner + "╗"
    if title and len(title) + 2 < inner:
        ins = f" {title} "
        pos = (inner - len(ins)) // 2
        top = "╔" + "═" * pos + ins + "═" * (inner - pos - len(ins)) + "╗"
    safe_add(win, y, x, top, attr)
    for r in range(1, h - 1):
        safe_add(win, y + r, x,         "║", attr)
        safe_add(win, y + r, x + w - 1, "║", attr)
    safe_add(win, y + h - 1, x, "╚" + "═" * inner + "╝", attr)


# ─── Scrollable log window ────────────────────────────────────────────────────

class LogWindow:
    """Curses pad that streams command output with \\r/\\n handling."""

    MAX_LINES = 3000

    def __init__(self, stdscr, y, x, height, width):
        self.stdscr  = stdscr
        self.y       = y
        self.x       = x
        self.height  = height
        self.width   = width
        self.pad     = curses.newpad(self.MAX_LINES, max(width, 1))
        self.pad.bkgd(" ", curses.color_pair(C_NORMAL))
        self.line    = 0   # current write line in pad
        self.col     = 0   # current write column
        self.scroll  = 0   # first visible line

    # ── internal writers ──

    def _newline(self):
        self.line += 1
        self.col   = 0
        if self.line >= self.MAX_LINES - 1:
            self.line = self.MAX_LINES - 2
        # auto-scroll to follow output
        if self.line >= self.scroll + self.height:
            self.scroll = self.line - self.height + 1

    def _write_chunk(self, text):
        """Write printable text at current cursor, wrapping at width."""
        for ch in text:
            if self.col >= self.width - 1:
                self._newline()
            if self.line < self.MAX_LINES - 1:
                try:
                    self.pad.addch(self.line, self.col, ch,
                                   curses.color_pair(C_NORMAL))
                    self.col += 1
                except curses.error:
                    pass

    # ── public API ──

    def write(self, text):
        """Write text, handling \\r (progress-bar rewind) and \\n."""
        i = 0
        while i < len(text):
            ch = text[i]
            if ch == "\r":
                if i + 1 < len(text) and text[i + 1] == "\n":
                    self._newline()
                    i += 2
                else:
                    # carriage return: overwrite current line
                    self.col = 0
                    try:
                        self.pad.move(self.line, 0)
                        self.pad.clrtoeol()
                    except curses.error:
                        pass
                    i += 1
            elif ch == "\n":
                self._newline()
                i += 1
            else:
                end = i + 1
                while end < len(text) and text[end] not in ("\r", "\n"):
                    end += 1
                self._write_chunk(text[i:end])
                i = end
        self.refresh()

    def scroll_by(self, delta):
        max_s = max(0, self.line - self.height + 1)
        self.scroll = max(0, min(max_s, self.scroll + delta))
        self.refresh()

    def refresh(self):
        try:
            self.pad.refresh(
                self.scroll, 0,
                self.y,                  self.x,
                self.y + self.height - 1, self.x + self.width - 1,
            )
        except curses.error:
            pass


# ─── Download progress tracker ───────────────────────────────────────────────

# Matches pacman's download progress lines after ANSI stripping, e.g.:
#   some-pkg-1.2-x86_64.pkg.tar.zst   5.2 MiB   2.1 MiB/s   00:02  [########  ]  80%
_DL_RE = re.compile(
    r"(\S+\.(?:pkg\.tar\.(?:zst|xz|gz|bz2)|sig))"
    r"\s{2,}([\d.]+\s*\w+(?:/s)?)"   # size
    r"\s{2,}([\d.]+\s*[\w/]+)"        # speed
    r"\s{2,}(\d+:\d+)"                # ETA
    r"\s+\[([^\]]+)\]"                # bar chars
    r"\s+(\d+)%"                       # percent
)
_PKG_NAME_RE = re.compile(
    r"^(.+?)-[^-]+-[^-]+-(?:x86_64|i686|any|aarch64)\.pkg\.tar\.\w+$"
)


class DownloadTracker:
    """Parses pacman download progress lines and renders a live table."""

    MAX_ROWS = 6
    DIVIDER  = "┄"

    def __init__(self):
        self._pkgs  = {}   # filename → {size, speed, eta, percent, done}
        self._order = []   # stable insertion order

    def feed(self, text):
        for line in re.split(r"[\r\n]", text):
            m = _DL_RE.search(line.strip())
            if not m:
                continue
            fname, size, speed, eta, bar, pct = (
                m.group(1), m.group(2), m.group(3),
                m.group(4), m.group(5), int(m.group(6)),
            )
            if fname not in self._pkgs:
                self._order.append(fname)
            self._pkgs[fname] = {
                "size":  size.strip(),
                "speed": speed.strip(),
                "eta":   eta,
                "pct":   pct,
                "done":  pct >= 100,
            }

    def has_entries(self):
        return bool(self._pkgs)

    def table_height(self):
        n = min(len(self._pkgs), self.MAX_ROWS)
        if n == 0:
            return 0
        return 2 + n + max(0, n - 1)   # header + divider + rows + inter-dividers

    def _display_name(self, fname):
        m = _PKG_NAME_RE.match(fname)
        return m.group(1) if m else fname

    def render_table(self, win, y, x, w):
        if not self._pkgs:
            return
        ba   = curses.color_pair(C_BORDER) | curses.A_BOLD
        hi   = curses.color_pair(C_HILITE) | curses.A_BOLD
        dim  = curses.color_pair(C_DIM)
        ok   = curses.color_pair(C_DL_DONE) | curses.A_BOLD
        norm = curses.color_pair(C_NORMAL)

        # Fixed column widths
        SZ_W, SPD_W, ETA_W, BAR_W, PCT_W = 9, 10, 5, 14, 4
        fixed   = SZ_W + SPD_W + ETA_W + BAR_W + PCT_W + 5
        name_w  = max(8, w - fixed - 2)

        # Header
        hdr = (f"{'Package':<{name_w}} "
               f"{'Size':>{SZ_W}} "
               f"{'Speed':>{SPD_W}} "
               f"{'ETA':>{ETA_W}} "
               f"{'':^{BAR_W}} "
               f"{'%':>{PCT_W}}")
        safe_add(win, y, x, hdr[:w], hi)
        y += 1
        safe_add(win, y, x, (self.DIVIDER * w)[:w], dim)
        y += 1

        visible = self._order[-self.MAX_ROWS:]
        for idx, fname in enumerate(visible):
            e    = self._pkgs[fname]
            pct  = e["pct"]
            filled   = int(BAR_W * pct / 100)
            bar_str  = "█" * filled + "░" * (BAR_W - filled)
            name     = self._display_name(fname)
            row = (f"{name:<{name_w}.{name_w}} "
                   f"{e['size']:>{SZ_W}} "
                   f"{e['speed']:>{SPD_W}} "
                   f"{e['eta']:>{ETA_W}} "
                   f"{bar_str} "
                   f"{pct:>{PCT_W}}%")
            safe_add(win, y, x, row[:w], ok if e["done"] else norm)
            y += 1
            if idx < len(visible) - 1:
                safe_add(win, y, x, (self.DIVIDER * w)[:w], dim)
                y += 1


# ─── Log-view chrome ──────────────────────────────────────────────────────────

#  Layout (rows = terminal height):
#
#  0        ╔═══[ pkgtui vX.X ]═══╗
#  1        ║  ● [1] Update  [2] Search …  ║   ← nav bar
#  2        ╠══════════════════════╣
#  3..N-3   ║  (log output)       ║         ← log area (side borders only)
#  N-2      ╠══════════════════════╣
#  N-1      ║  $ cmd …   [↑↓] Scroll [q]  ║   ← status bar

LOG_TOP  = 3   # first row of log content
LOG_BOT_OFFSET = 2   # rows reserved at bottom (separator + status)


def _log_geometry(rows, cols, table_h=0):
    """Return (log_y, log_x, log_h, log_w). table_h reserves rows above the log."""
    log_y = LOG_TOP + table_h
    log_h = rows - LOG_TOP - LOG_BOT_OFFSET - table_h
    log_x = 1
    log_w = cols - 2
    return log_y, log_x, max(log_h, 1), max(log_w, 1)


def draw_log_chrome(stdscr, active_idx, status="", is_done=False,
                    tracker=None, show_log=True, elapsed=0.0):
    rows, cols = stdscr.getmaxyx()
    ba = curses.color_pair(C_BORDER) | curses.A_BOLD

    # ── top border with title ──
    title = f" pkgtui v{VERSION} "
    inner = cols - 2
    pad_l = (inner - len(title)) // 2
    pad_r = inner - pad_l - len(title)
    safe_add(stdscr, 0, 0, "╔" + "═" * pad_l + title + "═" * pad_r + "╗", ba)

    # ── nav bar ──
    safe_add(stdscr, 1, 0,        "║", ba)
    safe_add(stdscr, 1, cols - 1,  "║", ba)
    safe_add(stdscr, 1, 1, " " * (cols - 2), curses.color_pair(C_DIM))
    nav_x = 2
    for i, (label, _) in enumerate(MENU_ITEMS):
        seg = ("● " if i == active_idx else "  ") + label + "   "
        if nav_x + len(seg) >= cols - 1:
            break
        attr = (curses.color_pair(C_ACTIVE) | curses.A_BOLD
                if i == active_idx else curses.color_pair(C_DIM))
        safe_add(stdscr, 1, nav_x, seg, attr)
        nav_x += len(seg)

    # ── separator ──
    safe_add(stdscr, 2, 0, "╠" + "═" * (cols - 2) + "╣", ba)

    # ── download table zone (optional) ──
    table_h = 0
    if tracker and tracker.has_entries():
        rows_avail = rows - LOG_TOP - LOG_BOT_OFFSET
        table_h = min(tracker.table_height(), rows_avail - 2)
        if table_h > 0:
            for r in range(LOG_TOP, LOG_TOP + table_h):
                safe_add(stdscr, r, 0,        "║", ba)
                safe_add(stdscr, r, cols - 1,  "║", ba)
            tracker.render_table(stdscr, LOG_TOP, 2, cols - 4)
            safe_add(stdscr, LOG_TOP + table_h, 0,
                     "╠" + "═" * (cols - 2) + "╣", ba)

    # ── log area side borders ──
    log_y, _, log_h, _ = _log_geometry(rows, cols, table_h)
    if show_log:
        for r in range(log_y, log_y + log_h):
            safe_add(stdscr, r, 0,        "║", ba)
            safe_add(stdscr, r, cols - 1,  "║", ba)

    # ── bottom separator ──
    safe_add(stdscr, rows - 2, 0, "╠" + "═" * (cols - 2) + "╣", ba)

    # ── status bar ──
    safe_add(stdscr, rows - 1, 0,        "║", ba)
    safe_add(stdscr, rows - 1, cols - 1,  "║", ba)
    safe_add(stdscr, rows - 1, 1, " " * (cols - 2), curses.color_pair(C_DIM))

    if is_done:
        msg = "  ✓  Done — press any key to return"
        safe_add(stdscr, rows - 1, 1, msg,
                 curses.color_pair(C_OK) | curses.A_BOLD)
    elif status:
        elapsed_str = f"  {int(elapsed)}s" if elapsed >= 1 else ""
        msg = f"  $ {status}{elapsed_str}"
        safe_add(stdscr, rows - 1, 1, msg[:cols // 2], curses.color_pair(C_NORMAL))

    hints = "[↑↓/PgUp/Dn] Scroll  [L] Toggle log  [q] Back "
    safe_add(stdscr, rows - 1, cols - len(hints) - 1, hints,
             curses.color_pair(C_DIM))

    stdscr.refresh()


# ─── Run commands in log window ───────────────────────────────────────────────

def run_in_log_window(stdscr, active_idx, cmd_list):
    """
    Stream each command's output into a curses log window.
    Uses a pty so pacman/yay keep their progress bars and colour.
    Returns True if all commands exited 0.
    """
    rows, cols  = stdscr.getmaxyx()
    tracker     = DownloadTracker()
    show_log    = True
    start_time  = time.monotonic()
    prev_table_h = 0

    log_y, log_x, log_h, log_w = _log_geometry(rows, cols, 0)
    log = LogWindow(stdscr, log_y, log_x, log_h, log_w)

    stdscr.clear()
    draw_log_chrome(stdscr, active_idx, tracker=tracker, show_log=show_log)
    log.refresh()

    stdscr.nodelay(True)
    all_ok  = True
    cmd_str = ""

    for cmd in cmd_list:
        cmd_str = " ".join(cmd)
        elapsed = time.monotonic() - start_time
        draw_log_chrome(stdscr, active_idx, cmd_str,
                        tracker=tracker, show_log=show_log, elapsed=elapsed)
        log.write(f"\n  $ {cmd_str}\n\n")

        master_fd, slave_fd = os.openpty()
        try:
            proc = subprocess.Popen(
                cmd,
                stdin=slave_fd,
                stdout=slave_fd,
                stderr=slave_fd,
                close_fds=True,
            )
        except Exception as exc:
            log.write(f"\n  Error starting process: {exc}\n")
            try:
                os.close(master_fd)
                os.close(slave_fd)
            except OSError:
                pass
            all_ok = False
            continue

        os.close(slave_fd)
        running = True

        while running:
            rlist, _, _ = select.select([master_fd], [], [], 0.05)

            if rlist:
                try:
                    data = os.read(master_fd, 4096)
                    if data:
                        text = strip_ansi(data.decode("utf-8", errors="replace"))
                        text = re.sub(r"(?<!\n)(\[sudo\]|Password:)", r"\n\1", text)
                        tracker.feed(text)
                        log.write(text)
                        # Reposition log window if table grew
                        new_th = tracker.table_height()
                        if new_th != prev_table_h:
                            log.y      = _log_geometry(rows, cols, new_th)[0]
                            log.height = _log_geometry(rows, cols, new_th)[2]
                            prev_table_h = new_th
                            stdscr.clear()
                        elapsed = time.monotonic() - start_time
                        draw_log_chrome(stdscr, active_idx, cmd_str,
                                        tracker=tracker, show_log=show_log,
                                        elapsed=elapsed)
                        if show_log:
                            log.refresh()
                except OSError:
                    running = False

            key = stdscr.getch()
            if key in (ord("q"), 27):
                proc.terminate()
                log.write("\n  [Interrupted by user]\n")
                running = False
            elif key in (ord("l"), ord("L")):
                show_log = not show_log
                th = tracker.table_height()
                log.y      = _log_geometry(rows, cols, th)[0]
                log.height = _log_geometry(rows, cols, th)[2]
                stdscr.clear()
                elapsed = time.monotonic() - start_time
                draw_log_chrome(stdscr, active_idx, cmd_str,
                                tracker=tracker, show_log=show_log, elapsed=elapsed)
                if show_log:
                    log.refresh()
            elif key == curses.KEY_UP:
                log.scroll_by(-1)
            elif key == curses.KEY_DOWN:
                log.scroll_by(1)
            elif key == curses.KEY_PPAGE:
                log.scroll_by(-(log_h // 2))
            elif key == curses.KEY_NPAGE:
                log.scroll_by(log_h // 2)
            elif key == curses.KEY_RESIZE:
                rows, cols = stdscr.getmaxyx()
                th = tracker.table_height()
                log.y = _log_geometry(rows, cols, th)[0]
                log.height = _log_geometry(rows, cols, th)[2]
                stdscr.clear()
                draw_log_chrome(stdscr, active_idx, cmd_str,
                                tracker=tracker, show_log=show_log, elapsed=elapsed)
                if show_log:
                    log.refresh()
            elif key in (curses.KEY_ENTER, 10, 13):
                try:
                    os.write(master_fd, b"\n")
                except OSError:
                    pass
            elif key != -1 and 32 <= key <= 126:
                try:
                    os.write(master_fd, chr(key).encode())
                except OSError:
                    pass

            if proc.poll() is not None:
                try:
                    while True:
                        r, _, _ = select.select([master_fd], [], [], 0.1)
                        if not r:
                            break
                        chunk = os.read(master_fd, 4096)
                        if not chunk:
                            break
                        text = strip_ansi(chunk.decode("utf-8", errors="replace"))
                        tracker.feed(text)
                        log.write(text)
                except OSError:
                    pass
                running = False

        try:
            os.close(master_fd)
        except OSError:
            pass

        ret = proc.wait()
        if ret != 0:
            all_ok = False
            log.write(f"\n  [Process exited with code {ret}]\n")
        else:
            log.write("\n  [✓ Done]\n")

    draw_log_chrome(stdscr, active_idx, is_done=True, tracker=tracker)
    stdscr.nodelay(False)
    stdscr.getch()

    stdscr.clear()
    stdscr.refresh()
    return all_ok


# ─── Main menu drawing ────────────────────────────────────────────────────────

def draw_menu(stdscr, sel):
    stdscr.erase()
    rows, cols = stdscr.getmaxyx()
    ba = curses.color_pair(C_BORDER) | curses.A_BOLD

    if rows < MIN_ROWS or cols < MIN_COLS:
        msg = f"Terminal too small ({cols}×{rows}). Need at least {MIN_COLS}×{MIN_ROWS}."
        safe_add(stdscr, rows // 2, max(0, (cols - len(msg)) // 2),
                 msg, curses.color_pair(C_ERROR) | curses.A_BOLD)
        stdscr.refresh()
        return

    draw_box(stdscr, 0, 0, rows, cols, ba, f" pkgtui v{VERSION} ")

    logo_row = 1
    logo_col = max(1, (cols - LOGO_W) // 2)
    for i, line in enumerate(LOGO):
        safe_add(stdscr, logo_row + i, logo_col, line, ba)

    sub = "Arch Linux Package Manager  •  CachyOS Edition"
    safe_add(stdscr, logo_row + len(LOGO), (cols - len(sub)) // 2,
             sub, curses.color_pair(C_DIM))

    sep_row = logo_row + len(LOGO) + 1
    safe_add(stdscr, sep_row, 0, "╠" + "═" * (cols - 2) + "╣", ba)

    menu_w = min(cols - 8, 52)
    menu_y = sep_row + 2
    menu_x = (cols - menu_w) // 2

    for i, (label, _) in enumerate(MENU_ITEMS):
        row = menu_y + i * 2
        border_char = "╔" if i == 0 else "╠"
        safe_add(stdscr, row, menu_x,
                 border_char + "═" * (menu_w - 2) + ("╗" if i == 0 else "╣"), ba)

        item_row = row + 1
        safe_add(stdscr, item_row, menu_x,         "║", ba)
        safe_add(stdscr, item_row, menu_x + menu_w - 1, "║", ba)

        arrow  = "▶ " if i == sel else "  "
        padded = f" {arrow}{label}".ljust(menu_w - 2)
        attr   = (curses.color_pair(C_SEL) | curses.A_BOLD
                  if i == sel else curses.color_pair(C_NORMAL))
        safe_add(stdscr, item_row, menu_x + 1, padded, attr)

    safe_add(stdscr, menu_y + len(MENU_ITEMS) * 2, menu_x,
             "╚" + "═" * (menu_w - 2) + "╝", ba)

    desc_row = menu_y + len(MENU_ITEMS) * 2 + 2
    _, desc = MENU_ITEMS[sel]
    box_w = min(menu_w, len(desc) + 8)
    box_x = (cols - box_w) // 2
    safe_add(stdscr, desc_row,     box_x,
             "╭" + "─" * (box_w - 2) + "╮", curses.color_pair(C_DIM))
    content = f"  ▸ {desc}  "
    safe_add(stdscr, desc_row + 1, box_x, "│", curses.color_pair(C_DIM))
    safe_add(stdscr, desc_row + 1, box_x + 1,
             content[:box_w - 2].ljust(box_w - 2),
             curses.color_pair(C_HILITE) | curses.A_BOLD)
    safe_add(stdscr, desc_row + 1, box_x + box_w - 1, "│", curses.color_pair(C_DIM))
    safe_add(stdscr, desc_row + 2, box_x,
             "╰" + "─" * (box_w - 2) + "╯", curses.color_pair(C_DIM))

    hint = "  [↑↓] Navigate    [Enter/Space] Select    [q/Esc] Quit  "
    safe_add(stdscr, rows - 2, (cols - len(hint)) // 2,
             hint, curses.color_pair(C_DIM))

    stdscr.refresh()


# ─── In-TUI search-query overlay ─────────────────────────────────────────────

def get_search_query(stdscr):
    rows, cols = stdscr.getmaxyx()
    bw, bh = 58, 5
    by = rows // 2 - bh // 2
    bx = (cols - bw) // 2

    win = curses.newwin(bh, bw, by, bx)
    win.bkgd(" ", curses.color_pair(C_NORMAL))
    draw_box(win, 0, 0, bh, bw,
             curses.color_pair(C_BORDER) | curses.A_BOLD,
             " Search packages ")
    safe_add(win, 2, 3, "Query: ", curses.color_pair(C_HILITE) | curses.A_BOLD)
    win.refresh()

    curses.echo()
    curses.curs_set(1)
    try:
        raw = win.getstr(2, 10, 40)
    except KeyboardInterrupt:
        raw = b""
    curses.noecho()
    curses.curs_set(0)

    del win
    stdscr.touchwin()
    stdscr.refresh()

    q = raw.decode("utf-8", errors="replace").strip()
    return q if q else None


# ─── Package search ───────────────────────────────────────────────────────────

def search_packages(query):
    """yay -Ss → list of tab-delimited lines: name\\tversion\\t[repo]\\tdesc"""
    try:
        result = subprocess.run(
            ["yay", "-Ss", query],
            capture_output=True, text=True, timeout=30,
        )
    except subprocess.TimeoutExpired:
        return []

    lines   = result.stdout.split("\n")
    pkgs    = []
    i       = 0
    while i < len(lines):
        line = lines[i]
        if line.startswith(" ->") or line.startswith("->") or not line.strip():
            i += 1
            continue
        m = re.match(r"^([a-zA-Z0-9_.+\-]+)/(\S+)\s+(\S+)", line)
        if m:
            repo, name, ver = m.group(1), m.group(2), m.group(3)
            desc = ""
            if i + 1 < len(lines) and lines[i + 1].startswith("    "):
                desc = lines[i + 1].strip()
                i += 1
            pkgs.append(f"{name}\t{ver}\t[{repo}]\t{desc}")
        i += 1
    return pkgs


# ─── fzf launcher ────────────────────────────────────────────────────────────

def run_fzf(items, prompt="Select: ", preview_cmd=None, header=None, multi=False):
    """Run fzf (must be called after curses.endwin()).
    Returns str|None when multi=False, list[str] when multi=True."""
    args = [
        "fzf",
        "--prompt", prompt,
        "--layout=reverse",
        "--border", "--border-label", " pkgtui ",
        "--color", FZF_COLORS,
        "--ansi", "--height=80%",
        "--bind", "ctrl-c:abort",
    ]
    if multi:
        args += ["--multi", "--bind", "tab:toggle+down,shift-tab:toggle+up"]
    if header:
        args += ["--header", header]
    if preview_cmd:
        args += ["--preview", preview_cmd, "--preview-window", "right:50%:wrap"]

    proc = subprocess.run(args, input="\n".join(items) + "\n",
                          capture_output=True, text=True)
    if proc.returncode != 0:
        return [] if multi else None
    raw = proc.stdout.strip()
    if multi:
        return [line for line in raw.splitlines() if line]
    return raw if raw else None


def _restore(stdscr):
    """Re-enter curses mode after endwin()."""
    curses.curs_set(0)
    stdscr.keypad(True)
    stdscr.clear()
    stdscr.refresh()


# ─── Operations ──────────────────────────────────────────────────────────────

def do_update(stdscr):
    run_in_log_window(stdscr, 0, [
        ["sudo", "pacman", "-Syu"],
        ["yay",  "-Syu"],
    ])


def do_search_install(stdscr):
    query = get_search_query(stdscr)
    if not query:
        return

    # fzf needs a real terminal → leave curses temporarily
    curses.endwin()
    print(f"\n  Searching for '{query}'…")
    packages = search_packages(query)

    if not packages:
        print(f"\n  No packages found matching '{query}'.")
        input("  Press Enter to continue…")
        _restore(stdscr)
        return

    selected = run_fzf(
        packages,
        prompt=f"  Install ({query}): ",
        preview_cmd="yay -Si {1} 2>/dev/null || pacman -Si {1} 2>/dev/null",
        header=(f"  {len(packages)} packages  •  [Tab] Multi-select  "
                "•  Enter: install  •  Esc: cancel"),
        multi=True,
    )

    _restore(stdscr)

    if selected:
        pkg_names = [s.split("\t")[0] for s in selected]
        run_in_log_window(stdscr, 1, [["yay", "-S"] + pkg_names])


def do_remove(stdscr):
    curses.endwin()
    print("\n  Loading installed packages…")
    result   = subprocess.run(["pacman", "-Qq"], capture_output=True, text=True)
    packages = [p for p in result.stdout.strip().split("\n") if p]

    if not packages:
        print("\n  No installed packages found.")
        input("  Press Enter to continue…")
        _restore(stdscr)
        return

    selected = run_fzf(
        packages,
        prompt="  Remove: ",
        preview_cmd="pacman -Qi {} 2>/dev/null",
        header=(f"  {len(packages)} packages installed  "
                "•  [Tab] Multi-select  •  Enter: remove  •  Esc: cancel"),
        multi=True,
    )

    _restore(stdscr)

    if selected:
        run_in_log_window(stdscr, 2, [["sudo", "pacman", "-Rs"] + selected])


# ─── Main loop ────────────────────────────────────────────────────────────────

def main(stdscr):
    curses.curs_set(0)
    stdscr.keypad(True)
    stdscr.timeout(-1)
    init_colors()

    sel = 0
    while True:
        draw_menu(stdscr, sel)
        key = stdscr.getch()

        if   key == curses.KEY_UP:
            sel = (sel - 1) % len(MENU_ITEMS)
        elif key == curses.KEY_DOWN:
            sel = (sel + 1) % len(MENU_ITEMS)
        elif key in (curses.KEY_ENTER, 10, 13, ord(" ")):
            if   sel == 0: do_update(stdscr)
            elif sel == 1: do_search_install(stdscr)
            elif sel == 2: do_remove(stdscr)
            elif sel == 3: break
        elif key in (ord("q"), ord("Q"), 27): break
        elif key == ord("1"): do_update(stdscr)
        elif key == ord("2"): do_search_install(stdscr)
        elif key == ord("3"): do_remove(stdscr)
        elif key == ord("4"): break
        elif key == curses.KEY_RESIZE: stdscr.clear()


# ─── Entry point ─────────────────────────────────────────────────────────────

def check_deps():
    return [t for t in ("fzf", "yay", "pacman") if not shutil.which(t)]


if __name__ == "__main__":
    missing = check_deps()
    if missing:
        print(f"\033[31m[pkgtui] Missing required tools: {', '.join(missing)}\033[0m",
              file=sys.stderr)
        sys.exit(1)

    locale.setlocale(locale.LC_ALL, "")
    try:
        curses.wrapper(main)
    except KeyboardInterrupt:
        pass

    print("\n  Goodbye!\n")
